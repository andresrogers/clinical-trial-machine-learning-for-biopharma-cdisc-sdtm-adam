{% macro render_page_shell(page_title, page_kicker, page_subtitle, nav, disclaimer, body_class='') -%}
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>{{ page_title }}</title>
    <style>
      :root {
        --ink: #18324a;
        --muted: #5b6b7d;
        --accent: #0a7f62;
        --accent-2: #1f4e79;
        --bg: #f5f8fb;
        --card: #ffffff;
        --border: #d9e2ec;
        --hero-a: #11324d;
        --hero-b: #1d567f;
        --hero-c: #1a7d6a;
      }
      body { font-family: Arial, sans-serif; margin: 0; background: var(--bg); color: var(--ink); }
      .page-wrap { max-width: 1180px; margin: 0 auto; padding: 28px; }
      .hero { background: linear-gradient(135deg, var(--hero-a), var(--hero-b) 62%, var(--hero-c)); color: white; padding: 30px 32px; border-radius: 18px; box-shadow: 0 10px 28px rgba(17, 50, 77, 0.18); }
      .hero .kicker { display: inline-block; margin-bottom: 10px; letter-spacing: 0.08em; text-transform: uppercase; font-size: 0.74rem; font-weight: 700; opacity: 0.88; }
      .hero h1 { margin: 0 0 10px; font-size: 2rem; }
      .hero p { margin: 0; max-width: 900px; line-height: 1.55; }
      .nav { margin-top: 18px; display: flex; flex-wrap: wrap; gap: 10px; }
      .nav a { color: white; text-decoration: none; padding: 8px 12px; border: 1px solid rgba(255,255,255,0.25); border-radius: 999px; font-size: 0.92rem; }
      .section-title { margin: 28px 0 12px; font-size: 1.25rem; }
      .card { background: var(--card); border: 1px solid var(--border); border-radius: 16px; padding: 18px; box-shadow: 0 6px 18px rgba(20, 38, 58, 0.05); margin-top: 16px; }
      .card.compact { padding: 14px 16px; }
      .metric-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 14px; margin-top: 18px; }
      .metric-label { color: var(--muted); font-size: 0.88rem; }
      .metric-value { margin-top: 8px; font-size: 1.25rem; font-weight: 700; }
      table { width: 100%; border-collapse: collapse; background: var(--card); border-radius: 12px; overflow: hidden; }
      th, td { padding: 11px 10px; border-bottom: 1px solid var(--border); text-align: left; vertical-align: top; font-size: 0.93rem; }
      th { background: #edf3f9; }
      img { max-width: 100%; border-radius: 12px; border: 1px solid var(--border); background: white; }
      ul.clean { margin: 0; padding-left: 1.1rem; }
      .badge { display: inline-block; padding: 5px 10px; border-radius: 999px; background: #e7f3ef; color: var(--accent); font-weight: 700; font-size: 0.82rem; }
      .footer-note { margin-top: 26px; padding: 16px; border-left: 4px solid var(--accent); background: #f0f7f4; color: var(--ink); }
      .muted { color: var(--muted); }
      .pre-card { white-space: pre-wrap; font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace; font-size: 0.88rem; line-height: 1.45; }
      .gallery { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 16px; }
      .links-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 12px; }
      .links-grid a { text-decoration: none; color: var(--accent-2); font-weight: bold; }
      .body-content { margin-top: 20px; }
      .grid { display: grid; gap: 16px; margin-top: 20px; }
      .flow { display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); gap: 10px; }
      .flow .box { background: white; border: 1px solid var(--border); border-radius: 14px; padding: 14px; text-align: center; font-weight: bold; }
    </style>
  </head>
  <body class="{{ body_class }}">
    <div class="page-wrap">
      <section class="hero">
        <div class="kicker">{{ page_kicker }}</div>
        <h1>{{ page_title }}</h1>
        <p>{{ page_subtitle }}</p>
        <div class="nav">
          {% for label, href in nav %}
          <a href="{{ href }}">{{ label }}</a>
          {% endfor %}
        </div>
      </section>
      <div class="body-content">
        {{ caller() }}
      </div>
      <div class="footer-note">
        <strong>Disclaimer:</strong> {{ disclaimer }}
      </div>
    </div>
  </body>
</html>
{%- endmacro %}
